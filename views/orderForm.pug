extends layout

block title
  title Order Movies

block content
  h1 Order Movies

  .dropdown
    select#serviceSelect
      option(value="" disabled selected) Select a Service

  #serviceInfo

  #genreBar

  h2#moviesTitle Movies

  #mainLayout
    #moviesColumn
      #movieList
    #orderColumn
      #orderSummary
      #feeSummary
      #totalsSummary
      #minMessages
      button#submitOrder(style="display:none") Submit Order

  // confirmation popup
  #confirmBox(style="display:none")
    p#confirmText
    button#confirmYes Yes
    button#confirmNo No

block scripts
  script.
    const streamingServices = !{JSON.stringify(services)}

  script(src="/web.js")
